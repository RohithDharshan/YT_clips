# Copy this file to .env and fill in real values. .env is gitignored.

# Google Cloud Console → APIs & Services → Credentials → OAuth Client ID
# (Web application). See README.md "Google Sign-In setup" for the exact steps.
GOOGLE_CLIENT_ID=

# Only Google accounts on this domain may sign in. Leave as gmail.com to
# restrict to personal Gmail accounts (rejects Workspace/other domains).
ALLOWED_EMAIL_DOMAIN=gmail.com

# Comma-separated list of browser origins allowed to call this API.
# "*" is rejected in production — Authorization-header requests require
# an explicit origin allowlist.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3005

# development | production — production disables verbose error detail in
# API responses and enforces ALLOWED_ORIGINS strictly.
ENV=development

MAX_UPLOAD_BYTES=1073741824
